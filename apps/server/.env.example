# 서버 포트 (idp-new의 Nook Backend 클라이언트 콜백이 localhost:4000 기준)
PORT=4000

# RP 세션/계정 저장용 postgres. nook 미러링 → 직접 채워넣기.
DATABASE_URL=postgres://user:pass@localhost:5432/nookbox

# better-auth 쿠키/토큰 서명 시크릿 (openssl rand -hex 32 등)
BETTER_AUTH_SECRET=
# RP 자기 자신의 base URL
BETTER_AUTH_URL=http://localhost:4000

# idp-new (OIDC IdP)
OIDC_ISSUER=http://localhost:3001/api/auth
OIDC_PROVIDER_ID=nook-auth
# idp-new seed-oauth-client.ts의 "Nook Backend" 클라이언트 재사용 → 그 값 그대로
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# 프론트 origin (CORS + 에러 리다이렉트). 웹 dev = 3030 (idp 로그인 UI가 3000이라 겹침 방지)
WEB_URL=http://localhost:3030
CORS_ORIGIN=http://localhost:3030
